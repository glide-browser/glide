+/**
+ * Write the *previous* version that was in `compatibility.ini` to a separate file
+ * so that we can use it inside `browser.mts` to display breaking change notifications.
+ *
+ * This will be removed in the future, as we now have `.glide/versions.json`, but we need
+ * this for any user on 0.1.53a or earlier.
+ */
+static void WriteCompatibilityOldestVersion(nsIFile* aProfileDir,
+                                     const nsCString& aVersion) {
+  nsCOMPtr<nsIFile> file;
+  aProfileDir->Clone(getter_AddRefs(file));
+  if (!file) return;
+
+  file->AppendNative(FILE_COMPATIBILITY_GLIDE_VERSION_BACKUP);
+
+  // if it exists then do nothing, as we just want the oldest version
+  bool exists;
+  nsresult rv = file->Exists(&exists);
+  if (NS_FAILED(rv) || exists) return;
+
+  PRFileDesc* fd;
+  rv = file->OpenNSPRFileDesc(PR_WRONLY | PR_CREATE_FILE | PR_TRUNCATE, 0600,
+                              &fd);
+  if (NS_FAILED(rv)) {
+    NS_ERROR("glide: could not create compatibility oldest version file");
+    return;
+  }
+
+  PR_Write(fd, aVersion.get(), aVersion.Length());
+
+  static const char kNL[] = NS_LINEBREAK;
+  PR_Write(fd, kNL, sizeof(kNL) - 1);
+
+  PR_Close(fd);
+}
